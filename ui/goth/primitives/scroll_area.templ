package primitives

// ScrollArea (P62, family F4 shipped native/no-controller). A single native
// overflow region: it scrolls with wheel/touch and, because it is a focusable
// named region (tabindex=0 + aria-label), with the keyboard. The themed scrollbar
// is pure CSS in components.css; no controller, no inline style.
templ ScrollArea(p ScrollAreaProps) {
	<div class={ scrollAreaClass(p) } { scrollAreaAttrs(p)... }>
		{ children... }
	</div>
}
