package primitives

// AspectRatio (P02, family F2) wraps content in a fixed-ratio box using the CSS
// aspect-ratio property selected by data-ratio (never an inline style). The
// principal content is templ children and fills the box. data-slot="aspect-ratio".
templ AspectRatio(p AspectRatioProps) {
	<div class={ aspectRatioClass(p) } { aspectRatioAttrs(p)... }>
		{ children... }
	</div>
}
