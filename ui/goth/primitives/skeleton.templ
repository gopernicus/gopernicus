package primitives

// Skeleton (P22, family F1) is a decorative loading placeholder. It renders an
// empty, aria-hidden box; its pulse animation is CSS-only and disabled under
// prefers-reduced-motion. It never announces (no live region). data-slot="skeleton".
templ Skeleton(p SkeletonProps) {
	<div class={ skeletonClass(p) } { skeletonAttrs(p)... }></div>
}
