package primitives

// Direction (P09, family F1) wraps its children in an element carrying the native
// dir attribute so a subtree can override the document direction. The dir
// attribute is inherited by descendants, giving RTL/LTR propagation without any
// script. data-slot="direction".
templ Direction(p DirectionProps) {
	<div class={ directionClass(p) } { directionAttrs(p)... }>
		{ children... }
	</div>
}
