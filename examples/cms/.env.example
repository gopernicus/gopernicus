# examples/cms — environment template. Copy to .env and fill in.
# All values here are non-secret placeholders; never commit real credentials.

# --- HTTP server ---
HOST=localhost                 # bind host
PORT=8080                      # bind port
SHUTDOWN_TIMEOUT=10s           # graceful-shutdown budget (also bounds tracer flush)

# --- Logging ---
LOG_LEVEL=INFO                 # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json                # json | text
LOG_OUTPUT=STDERR              # STDERR | STDOUT

# --- Datastore (Turso / libsql) ---
TURSO_DATABASE_URL=            # libsql://... remote, or file:///abs/path.db for local
TURSO_AUTH_TOKEN=              # required for a remote Turso URL; empty for file:// DSNs

# --- Tracing (integrations/tracing/otel) ---
# TRACING_ENABLED gates the TRACER CHOICE, not the middleware: false (or unset)
# wires a no-op tracer; true builds an OpenTelemetry tracer from the knobs below.
# NOTE: with tracing enabled, each request's client IP and user-agent are sent to
# the configured trace backend as span attributes.
TRACING_ENABLED=false          # true → real spans; false/unset → no-op
TRACING_EXPORTER=stdout        # stdout | otlpgrpc | provider
TRACING_SERVICE_NAME=gopernicus # service.name on every span; also names the tracer
TRACING_SERVICE_VERSION=       # optional service.version resource attribute
TRACING_ENVIRONMENT=           # optional deployment.environment.name resource attribute
TRACING_SAMPLE_RATE=1          # OTLP head-sampling ratio [0,1]; stdout always samples
TRACING_OTLP_ENDPOINT=         # otlpgrpc collector host:port (empty → localhost:4317)
TRACING_OTLP_INSECURE=false    # true disables transport security for otlpgrpc
TRACING_STDOUT_PRETTY=false     # true indents the stdout exporter's JSON
