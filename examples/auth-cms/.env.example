# examples/auth-cms — environment template. Copy to .env and fill in.
# All values here are non-secret PLACEHOLDERS; never commit real credentials.

# --- HTTP server ---
HOST=localhost                 # bind host
PORT=8082                      # bind port

# --- Logging ---
LOG_LEVEL=INFO                 # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=text                # text | json  (the console mailer logs codes/tokens here)
LOG_OUTPUT=STDERR              # STDERR | STDOUT

# --- JWT access + refresh sessions (auth-jwt plan) ---------------------------
# The access credential is now a REQUIRED signed JWT (the signer can no longer be
# nil). AUTH_JWT_SECRET signs it and the session anchor's refresh rotation. It
# MUST be at least 32 bytes. If UNSET, the host generates an EPHEMERAL RANDOM key
# at boot — a DEV / SINGLE-INSTANCE convenience: access JWTs do NOT survive a
# restart (a fresh key can't verify an old token), though API clients recover via
# POST /auth/refresh (refresh tokens are DB/store-backed). A MULTI-INSTANCE
# deployment behind a load balancer MUST set a shared AUTH_JWT_SECRET across every
# instance — per-instance ephemeral keys cannot cross-verify and auth flaps on
# every request. A committed constant is a leak, so this host never ships one.
AUTH_JWT_SECRET=               # >=32 bytes; unset => ephemeral single-instance dev key
#
# AUTH_ACCESS_TOKEN_TTL is the access-JWT lifetime (a Go duration); empty => 15m.
# Keep it short — it bounds the revocation-asymmetry window on stateless
# RequireUser routes (RequireLiveSession routes revoke immediately). A short value
# (e.g. AUTH_ACCESS_TOKEN_TTL=1s) drives the expired-access-JWT proof legs.
AUTH_ACCESS_TOKEN_TTL=         # e.g. 15m, 1s; empty => 15m
#
# AUTH_REFRESH_TTL is the fixed refresh-token / session horizon (a Go duration);
# empty => 168h (7d). It is set at mint and NEVER extended by rotation (a stolen
# refresh token therefore cannot outlive it).
AUTH_REFRESH_TTL=              # e.g. 168h; empty => 7d

# --- Provider-token encryption (design §3) -----------------------------------
# AUTH_TOKEN_ENCRYPTER_KEY, when set, must be EXACTLY 32 bytes and enables
# AES-256-GCM encryption of provider access/refresh tokens at rest. Unset =>
# provider tokens are NOT persisted (login and linking still work) — a safe,
# documented degradation. No real key ever lands in this file.
AUTH_TOKEN_ENCRYPTER_KEY=      # exactly 32 bytes (32 ASCII chars); unset => tokens not stored

# --- Auth v3 secrets: FIVE DISTINCT keys (design §3.3/§4.4/§6.1.1) ------------
# Each auth key has a SEPARATE purpose and MUST be a distinct value — one key is
# never reused across roles (a compromise of one must not compromise the others),
# and no key material is ever printed (only a WARN when a key is ephemeral). Every
# key below, when UNSET, falls back to an EPHEMERAL random per-boot key: a DEV /
# SINGLE-INSTANCE convenience only (values do not survive a restart, and a
# MULTI-INSTANCE deployment MUST set + share every key). Distinct from AUTH_JWT_SECRET
# (session/JWT signing) and AUTH_TOKEN_ENCRYPTER_KEY (provider tokens) above.
#
# AUTH_CHALLENGE_PEPPER protects short OTP codes with an in-process HMAC key ring
# (design §3.3, §11). Hex, >= 32 bytes. Its active key ID stamps each issued
# challenge so an overlapping rotation still verifies an unexpired code.
AUTH_CHALLENGE_PEPPER=         # hex, >=32 bytes; unset => ephemeral single-instance dev pepper
#
# AUTH_IDENTIFIER_KEY derives PII-free rate-limit / outbox idempotency digests with a
# stable HMAC (design §4.4). Hex, >= 32 bytes. Deliberately separate from the pepper,
# JWT, and encryption keys; production requires it shared across instances.
AUTH_IDENTIFIER_KEY=          # hex, >=32 bytes; unset => ephemeral single-instance dev key
#
# AUTH_DELIVERY_ENCRYPTER_KEY seals the durable delivery-outbox payload envelope with
# AES-256-GCM (design §6.1.1) — pending jobs briefly carry the rendered secret +
# destination. EXACTLY 32 bytes. An ephemeral key strands any in-flight job on restart.
AUTH_DELIVERY_ENCRYPTER_KEY=  # exactly 32 bytes (32 ASCII chars); unset => ephemeral single-instance dev key

# --- Auth v3 HTML surface + passwordless + magic links (design §4.2/§6.4/§9) --
# This host wires the bundled default templ Views (auth.Config.Views), so normal HTML
# GET pages + form handling mount alongside the unchanged JSON API. The knobs below
# tune the browser-safe surface; all have safe development defaults.
#
# AUTH_PUBLIC_BASE_URL is the absolute base URL magic links are built from (design
# §6.4): the framework appends "#token=<token>" to it, so it must point at the page that
# hosts the fragment-reading landing script — here the bundled landing GET at
# /auth/magic. Request Host/forwarded headers NEVER participate. Empty => this host's own
# http://HOST:PORT/auth/magic. Production RuntimeMode REQUIRES an https:// value.
AUTH_PUBLIC_BASE_URL=          # e.g. https://app.example.com/auth/magic; empty => http://HOST:PORT/auth/magic
#
# AUTH_ALLOWED_ORIGINS is the comma-separated exact-match Origin allowlist the
# browser-safe mutation gate validates cookie-authenticated sensitive mutations and
# HTML form posts against (design §9.1). Empty => this host's own origin. A "*" entry
# never authorizes a credentialed cross-origin mutation.
AUTH_ALLOWED_ORIGINS=          # e.g. https://app.example.com; empty => http://HOST:PORT
#
# AUTH_PASSWORDLESS is the comma-separated set of identifier kinds passwordless login
# is enabled for (design §4.2); allowed kinds are email and phone. Empty => both
# (email magic link + OTP, phone OTP via the console notifier). Set to a subset to
# narrow it; each listed kind needs a wired delivery channel or construction fails.
AUTH_PASSWORDLESS=             # e.g. email,phone; empty => email,phone

# --- Debug audit route (plan-cut amendment, SRE) -----------------------------
# AUTH_DEBUG=1 registers GET /debug/security-events. It is DEFAULT-OFF because it
# dumps IP/UA/emails and this host is public; it is ADDITIONALLY session-gated
# (RequireUser). Unset => the route is not registered (404).
AUTH_DEBUG=                    # 1 enables GET /debug/security-events (session-gated)

# --- OAuth provider (design §3) ----------------------------------------------
# This proof host wires a HOST-LOCAL FAKE provider (no vendor, no network), so
# these are unused here — they are placeholders for a real host swapping in
# integrations/oauth/google or integrations/oauth/github via auth.Config.Providers.
# Never commit real client secrets.
OAUTH_CLIENT_ID=               # a real provider's client id (unused by the fake provider)
OAUTH_CLIENT_SECRET=           # a real provider's client secret (unused by the fake provider)
