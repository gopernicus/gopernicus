package turso

import (
	"context"

	tursodb "github.com/gopernicus/gopernicus/integrations/datastores/turso"
	"github.com/gopernicus/gopernicus/sdk"
)

// queryOne runs a single-row query and scans it into a db-tagged row struct via
// tursodb.ScanStruct. It routes the read through Query (not QueryRow) so the row
// carries Columns for the strict struct scan, then steps exactly one row. A
// no-rows result maps to sdk.ErrNotFound and every driver error to its sentinel
// through MapError.
func queryOne[T any](ctx context.Context, db tursodb.Querier, query string, args ...any) (T, error) {
	var zero T
	rows, err := db.Query(ctx, query, args...)
	if err != nil {
		return zero, tursodb.MapError(err)
	}
	defer rows.Close()
	if !rows.Next() {
		if err := rows.Err(); err != nil {
			return zero, tursodb.MapError(err)
		}
		return zero, sdk.ErrNotFound
	}
	return tursodb.ScanStruct[T](rows)
}
