# {{.ModulePath}} — environment template. Copy to .env and fill in.
# All values here are non-secret placeholders; never commit real credentials.

# --- HTTP server ---
HOST=localhost
PORT={{.Port}}
SHUTDOWN_TIMEOUT=10s

# --- Logging ---
LOG_LEVEL=INFO      # DEBUG | INFO | WARN | ERROR
LOG_FORMAT=json     # json | text
LOG_OUTPUT=STDERR   # STDERR | STDOUT
{{- if eq .DB "turso"}}

# --- Datastore (Turso / libSQL) ---
TURSO_DATABASE_URL=   # libsql://... remote, or file:///abs/path.db for local
TURSO_AUTH_TOKEN=     # required for a remote Turso URL; empty for file:// DSNs
{{- end}}
{{- if eq .DB "pgx"}}

# --- Datastore (PostgreSQL / pgx) ---
# Set DB_URL for a full DSN, or the split fields below (one or the other).
DB_URL=               # postgres://user:pass@host:5432/db?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
DB_SSLMODE=disable
{{- end}}
