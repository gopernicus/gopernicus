# Turso / libSQL remote database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# HTTP server
HOST=localhost
PORT=8080
SHUTDOWN_TIMEOUT=10s

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=STDERR

# Media (disk-backed uploads)
MEDIA_DIR=media-data

# Email — leave SMTP_HOST empty to use the console sender (logs mail) in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=cms@localhost
CONTACT_EMAIL=ops@localhost
